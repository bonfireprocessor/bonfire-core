#!/usr/bin/env bash
set -euo pipefail

# bonfire-core: universal frontend for the bonfire-core development environment.
#
# - Prepares the local Python/toolchain environment
# - Passes explicit test invocations through to pytest (--pytest -- ...)
# - Starts the simulated GDB server (--gdbserver [--hex PATH] [--port N])
# - Starts the OpenOCD remote_bitbang server (--openocd-bitbang [--hex PATH] [--port N])

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CODE_DIR="$ROOT_DIR/code"

TOOLCHAIN_BIN_DEFAULT="$HOME/opt/riscv-gnu-toolchain/bin"
TOOLCHAIN_BIN="${TOOLCHAIN_BIN:-$TOOLCHAIN_BIN_DEFAULT}"

# TARGET_PREFIX can be either:
# - a plain prefix like "riscv64-unknown-elf"
# - OR a full path prefix like "/opt/.../bin/riscv64-unknown-elf"
TARGET_PREFIX="${TARGET_PREFIX:-riscv64-unknown-elf}"

DEFAULT_GDBSERVER_HEX="code/build/debug-tests/endless.hex"

usage() {
  cat <<'USAGE'
bonfire-core - bonfire-core universal runner

Usage:
  scripts/bonfire-core [OPTIONS] -- [PYTEST_ARGS...]

Pytest:
  --pytest          Run pytest. All arguments after "--" are passed to pytest.

Server modes:
  --gdbserver       Start the simulated GDB server instead of running pytest
  --openocd-bitbang Start the OpenOCD remote_bitbang JTAG/Core simulation server
  --hex PATH        Server HEX image to load
                    (default: code/build/debug-tests/endless.hex)
  --port N          Server TCP port (GDB default: first free port in 5500-5550,
                    OpenOCD bitbang default: 3335)
  --debug-trace     With --openocd-bitbang: print Debug Module/progbuf trace
  --info-trace      With --openocd-bitbang: print compact hart/abstract-command trace

Environment / venv:
  --install         Create/update ./.venv and install Python deps (runs scripts/install.sh)
  --keepenv         Do not activate ./.venv; keep current Python environment
                    (also via BONFIRE_CORE_KEEPENV=1)

Other:
  --help, -h        Show this help

Examples:
  scripts/bonfire-core --pytest -- --collect-only
  scripts/bonfire-core --pytest -- tests/test_debug_module.py::test_debug_module_jtag -s -vv --waveform
  scripts/bonfire-core --gdbserver --hex code/build/debug-tests/endless.hex --port 5500
  scripts/bonfire-core --openocd-bitbang --hex code/build/debug-tests/endless.hex --port 3335 --debug-trace
  scripts/bonfire-core --openocd-bitbang --port 3335 --info-trace
USAGE
}

RUN_PYTEST=0
RUN_GDBSERVER=0
RUN_OPENOCD_BITBANG=0
OPENOCD_DEBUG_TRACE=0
OPENOCD_INFO_TRACE=0
DO_INSTALL=0
KEEPENV=0

TB_HEX=""
SERVER_PORT=""

PYTEST_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;

    --install)
      DO_INSTALL=1
      shift
      ;;

    --keepenv)
      KEEPENV=1
      shift
      ;;

    --pytest)
      RUN_PYTEST=1
      shift
      ;;

    --gdbserver)
      RUN_GDBSERVER=1
      shift
      ;;

    --openocd-bitbang)
      RUN_OPENOCD_BITBANG=1
      shift
      ;;

    --debug-trace)
      OPENOCD_DEBUG_TRACE=1
      shift
      ;;

    --info-trace)
      OPENOCD_INFO_TRACE=1
      shift
      ;;

    --port)
      SERVER_PORT="${2:-}"
      [[ -n "$SERVER_PORT" ]] || { echo "ERROR: --port requires a value" >&2; exit 2; }
      shift 2
      ;;

    --hex)
      TB_HEX="${2:-}"
      [[ -n "$TB_HEX" ]] || { echo "ERROR: --hex requires a value" >&2; exit 2; }
      shift 2
      ;;

    --)
      shift
      PYTEST_ARGS+=("$@")
      break
      ;;

    *)
      echo "ERROR: unknown option: $1" >&2
      echo "Hint: use --pytest -- <args> to pass arguments to pytest" >&2
      exit 2
      ;;
  esac
done

if [[ "${BONFIRE_CORE_KEEPENV:-}" == "1" ]]; then
  KEEPENV=1
fi

mode_count=$((RUN_PYTEST + RUN_GDBSERVER + RUN_OPENOCD_BITBANG))
if [[ $mode_count -ne 1 ]]; then
  echo "ERROR: choose exactly one mode: --pytest, --gdbserver, or --openocd-bitbang" >&2
  exit 2
fi

if [[ $OPENOCD_DEBUG_TRACE -eq 1 && $RUN_OPENOCD_BITBANG -eq 0 ]]; then
  echo "ERROR: --debug-trace requires --openocd-bitbang" >&2
  exit 2
fi

if [[ $OPENOCD_INFO_TRACE -eq 1 && $RUN_OPENOCD_BITBANG -eq 0 ]]; then
  echo "ERROR: --info-trace requires --openocd-bitbang" >&2
  exit 2
fi

if [[ $RUN_PYTEST -eq 1 ]]; then
  if [[ -n "$TB_HEX$SERVER_PORT" || $OPENOCD_DEBUG_TRACE -eq 1 || $OPENOCD_INFO_TRACE -eq 1 ]]; then
    echo "ERROR: --pytest does not accept --hex, --port, --debug-trace, or --info-trace" >&2
    echo "Hint: pass pytest options after --, e.g. --pytest -- tests/test_core.py --bonfire-hex path.hex" >&2
    exit 2
  fi
else
  if [[ ${#PYTEST_ARGS[@]} -ne 0 ]]; then
    echo "ERROR: server modes do not accept pytest arguments" >&2
    exit 2
  fi
fi

if [[ $DO_INSTALL -eq 1 ]]; then
  "$ROOT_DIR/scripts/install.sh"
fi

if [[ $KEEPENV -eq 0 ]]; then
  if [[ ! -d "$ROOT_DIR/.venv" ]]; then
    echo "ERROR: Python venv not found at $ROOT_DIR/.venv (use --install or create it)" >&2
    exit 2
  fi
  # shellcheck disable=SC1091
  . "$ROOT_DIR/.venv/bin/activate"
fi

resolve_toolchain() {
  if [[ "$TARGET_PREFIX" == */* ]]; then
    GCC="${TARGET_PREFIX}-gcc"
    TOOLCHAIN_BIN_RESOLVED="$(dirname "$TARGET_PREFIX")"
  else
    GCC="$TOOLCHAIN_BIN/${TARGET_PREFIX}-gcc"
    TOOLCHAIN_BIN_RESOLVED="$TOOLCHAIN_BIN"
  fi

  if [[ ! -x "$GCC" ]]; then
    echo "ERROR: toolchain not found: $GCC" >&2
    echo "Hint: either set TARGET_PREFIX=riscv64-unknown-elf (and TOOLCHAIN_BIN=/path/to/bin)" >&2
    echo "      or set TARGET_PREFIX=/path/to/bin/riscv64-unknown-elf" >&2
    exit 2
  fi

  export PATH="$TOOLCHAIN_BIN_RESOLVED:$PATH"
}

pushd "$ROOT_DIR" >/dev/null

if [[ $RUN_PYTEST -eq 1 ]]; then
  exec python -m pytest "${PYTEST_ARGS[@]}"
fi

if [[ -z "$TB_HEX" ]]; then
  resolve_toolchain
  TB_HEX="$DEFAULT_GDBSERVER_HEX"
  pushd "$CODE_DIR" >/dev/null
  make -B debug-tests TARGET_PREFIX="$TARGET_PREFIX" KEEP_ELF=1
  popd >/dev/null
elif [[ ! -f "$TB_HEX" ]]; then
  echo "ERROR: HEX file not found: $TB_HEX" >&2
  exit 2
fi

if [[ $RUN_GDBSERVER -eq 1 ]]; then
  GDBSERVER_CMD=(python -m gdbserver --hex "$TB_HEX")
  if [[ -n "$SERVER_PORT" ]]; then
    GDBSERVER_CMD+=(--port "$SERVER_PORT")
  fi

  exec "${GDBSERVER_CMD[@]}"
fi

if [[ $RUN_OPENOCD_BITBANG -eq 1 ]]; then
  OPENOCD_BITBANG_CMD=(python -m openocd_bitbang --hex "$TB_HEX")
  if [[ -n "$SERVER_PORT" ]]; then
    OPENOCD_BITBANG_CMD+=(--port "$SERVER_PORT")
  fi
  if [[ $OPENOCD_DEBUG_TRACE -eq 1 ]]; then
    OPENOCD_BITBANG_CMD+=(--debug-trace)
  fi
  if [[ $OPENOCD_INFO_TRACE -eq 1 ]]; then
    OPENOCD_BITBANG_CMD+=(--info-trace)
  fi

  exec "${OPENOCD_BITBANG_CMD[@]}"
fi

popd >/dev/null
